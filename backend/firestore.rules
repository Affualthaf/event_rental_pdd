rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ────────────────────────────────────────────────────

    /// Returns true when the caller is signed in.
    function isAuthenticated() {
      return request.auth != null;
    }

    /// Returns the caller's uid.
    function uid() {
      return request.auth.uid;
    }

    /// Reads the caller's role from the users collection.
    /// Returns '' when the document does not yet exist (e.g. mid sign-up).
    function userRole() {
      let doc = get(/databases/$(database)/documents/users/$(uid()));
      return doc.data.get('role', '');
    }

    function isVendor() {
      return isAuthenticated() && userRole() == 'Vendor';
    }

    function isAdmin() {
      return isAuthenticated() && userRole() == 'Admin';
    }

    // ─── Users ───────────────────────────────────────────────────────────────
    //
    // • Any authenticated user can read any user profile (needed for vendor
    //   discovery and chat participant-name look-ups).
    // • A user can create/update only their own document.
    // • Admins can read and write any user document.

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && uid() == userId;
      allow update: if isAuthenticated() && (uid() == userId || isAdmin());
      allow delete: if isAdmin();
    }

    // ─── Equipment / Products ────────────────────────────────────────────────
    //
    // • Any authenticated user can browse equipment.
    // • Only vendors can create equipment, and only for their own vendorId.
    // • Only the owning vendor (or an admin) can update/delete.

    match /equipment/{itemId} {
      allow read: if isAuthenticated();
      allow create: if isVendor()
                    && request.resource.data.vendorId == uid();
      allow update, delete: if isAuthenticated()
                            && (resource.data.vendorId == uid() || isAdmin());
    }

    // ─── Orders ──────────────────────────────────────────────────────────────
    //
    // • Customers can create orders; the customerId field must match their uid.
    // • A customer can read only their own orders (customerId == uid).
    // • A vendor can read orders addressed to them (vendorId == uid).
    // • Vendors can update status/tracking fields on their own orders.
    // • Admins have full access.

    match /orders/{orderId} {
      allow create: if isAuthenticated()
                    && request.resource.data.customerId == uid();

      allow read: if isAuthenticated()
                  && (
                       resource.data.customerId == uid()   // own order (customer)
                    || resource.data.vendorId   == uid()   // vendor's order
                    || isAdmin()
                  );

      allow update: if isAuthenticated()
                    && (
                         resource.data.vendorId == uid()   // vendor updates status
                      || resource.data.customerId == uid() // customer edits (rare)
                      || isAdmin()
                    );

      allow delete: if isAdmin();
    }

    // ─── Chats ───────────────────────────────────────────────────────────────
    //
    // • Only the two participants of a chat can read or write the chat document
    //   and its messages sub-collection.

    match /chats/{chatId} {
      allow read, write: if isAuthenticated()
                         && uid() in resource.data.participants;

      // Allow create when the document doesn't yet exist (first message).
      allow create: if isAuthenticated()
                    && uid() in request.resource.data.participants;

      match /messages/{messageId} {
        // Re-check at message level: uid must be in the parent chat's participants.
        allow read, write: if isAuthenticated()
                           && uid() in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }
    }

    // ─── Catch-all: deny everything else ─────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
